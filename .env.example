# =============================================================================
# 청연(cheongyeon) — 로컬 개발용 환경 변수 템플릿
# 사용법: 이 파일을 복사해 `.env` 로 저장한 뒤 YOUR_* 값을 실제 키로 교체하세요.
# =============================================================================

# --- Supabase (Vite 클라이언트 — 공개 가능한 키만) ---
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# OAuth 로그인 후 돌아올 사이트 URL (로컬)
VITE_SITE_URL=http://localhost:5173

# --- 카카오 로그인 (직접 OAuth — REST API 키, 공개 가능) ---
# Kakao Developers → 앱 키 → REST API 키
VITE_KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# --- 카카오 로그인 API (서버 전용 — Vercel / 로컬 Vite dev) ---
# Vercel: 아래 4개를 VITE_ 없이 등록 (KAKAO_REST_API_KEY는 VITE_ 값과 동일해도 됨)
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# =============================================================================
# Vercel API Route (/api/kakao-auth) — Supabase Edge Function 대신 사용
# =============================================================================
# Git push 후 Vercel이 api/kakao-auth.ts 를 자동 배포합니다.
# 위 서버 전용 4개 변수를 Vercel에 반드시 등록하세요.
#
# (선택) Supabase Edge Function을 쓸 경우에만:
#   supabase functions deploy kakao-auth
#
# =============================================================================
# Kakao Developers — 직접 OAuth Redirect URI
# =============================================================================
# 제품 설정 → 카카오 로그인 → Redirect URI:
#   - http://localhost:5173/auth/kakao/callback
#   - https://YOUR_DOMAIN.vercel.app/auth/kakao/callback
#
# 동의항목:
#   - profile_nickname : 필수 동의
#   - profile_image    : 선택 동의
#   - account_email    : 사용 안 함
#
# =============================================================================
# Supabase SQL
# =============================================================================
# supabase/patch-kakao-direct-oauth.sql 실행 (kakao_id 컬럼 + 트리거)
#
# =============================================================================
# Vercel Environment Variables
# =============================================================================
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# VITE_SITE_URL
# VITE_KAKAO_REST_API_KEY
# VITE_KAKAO_MAP_APP_KEY
# KAKAO_REST_API_KEY
# KAKAO_CLIENT_SECRET
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY