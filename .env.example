# =============================================================================
# 청연(cheongyeon) — 로컬 개발용 환경 변수 템플릿
# 사용법: 이 파일을 복사해 `.env` 로 저장한 뒤 YOUR_* 값을 실제 키로 교체하세요.
# =============================================================================

# --- Supabase (Vite 클라이언트 — 공개 가능한 키만) ---
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# OAuth 로그인 후 돌아올 사이트 URL (로컬)
VITE_SITE_URL=http://localhost:5173

# --- Kakao 로그인 (직접 OAuth — REST API 키, 공개 가능) ---
# Kakao Developers → 앱 키 → REST API 키
VITE_KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# --- Kakao 지도 (Location 페이지) ---
VITE_KAKAO_MAP_APP_KEY=YOUR_KAKAO_JAVASCRIPT_KEY

# =============================================================================
# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
# =============================================================================
# KAKAO_REST_API_KEY   = Kakao REST API 키
# KAKAO_CLIENT_SECRET  = Kakao REST API 키 → Client Secret
#
# 배포:
#   supabase login
#   supabase link --project-ref YOUR_PROJECT_REF
#   supabase secrets set KAKAO_REST_API_KEY=... KAKAO_CLIENT_SECRET=...
#   supabase functions deploy kakao-auth
#
# =============================================================================
# Kakao Developers — 직접 OAuth Redirect URI
# =============================================================================
# 제품 설정 → 카카오 로그인 → Redirect URI:
#   - http://localhost:5173/auth/kakao/callback
#   - https://YOUR_DOMAIN.vercel.app/auth/kakao/callback
#
# 동의항목:
#   - profile_nickname : 필수 동의
#   - profile_image    : 선택 동의
#   - account_email    : 사용 안 함
#
# =============================================================================
# Supabase SQL
# =============================================================================
# supabase/patch-kakao-direct-oauth.sql 실행 (kakao_id 컬럼 + 트리거)
#
# =============================================================================
# Vercel Environment Variables
# =============================================================================
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# VITE_SITE_URL
# VITE_KAKAO_REST_API_KEY
# VITE_KAKAO_MAP_APP_KEY
